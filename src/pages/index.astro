---
import { GoogleFontsOptimizer } from 'astro-google-fonts-optimizer'

import GalleryHead from '@/components/GalleryHead.astro'
import Navbar from '@/components/Navbar.astro'
import Hero from '@/components/Hero.astro'
import VenueSection from '@/components/VenueSection.astro'
import ScheduleSection from '@/components/ScheduleSection.astro'
import ThemeSection from '@/components/ThemeSection.astro'
import FAQSection from '@/components/FAQSection.astro'
import CreditsSection from '@/components/CreditsSection.astro'
import Footer from '@/components/Footer.astro'

import { SITE_TITLE, SITE_DESCRIPTION } from '@/config'
import { themes } from '@/data/themes'

const themeLinks = themes.map(({ id, number, title }) => ({ id, number, title }))
---

<!doctype html>
<html lang="th">
  <head>
    <GalleryHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <GoogleFontsOptimizer
      url="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;600&family=Pattaya&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500&display=swap"
    />
    <script>
      import * as Cronitor from '@cronitorio/cronitor-rum'

      // Load the Cronitor tracker once in your app
      Cronitor.load('04303faac1a2afad07841827c06697f6', {
        debug: false,
        trackMode: 'pageload',
      })
    </script>
  </head>
  <body>
    <div id="top" class="min-h-screen">
      <Navbar themes={themeLinks} />
      <Hero themes={themeLinks} />
      <VenueSection />
      <ScheduleSection />
      <div id="gallery">
        {themes.map((theme) => <ThemeSection theme={theme} />)}
      </div>
      <FAQSection />
      <CreditsSection />
      <Footer />
    </div>
    <script>
      const root = document.documentElement
      const themeSections = Array.from(document.querySelectorAll('[data-theme-section]'))

      if (root && themeSections.length > 0) {
        const visibleRatios = new Map()

        const updateActiveTheme = () => {
          let activeTheme = ''
          let maxRatio = 0

          for (const section of themeSections) {
            const ratio = visibleRatios.get(section.id) ?? 0
            if (ratio > maxRatio) {
              maxRatio = ratio
              activeTheme = section.getAttribute('data-theme-section') || ''
            }
          }

          if (activeTheme && maxRatio >= 0.18) {
            root.setAttribute('data-active-theme', activeTheme)
          } else {
            root.removeAttribute('data-active-theme')
          }
        }

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              visibleRatios.set(entry.target.id, entry.isIntersecting ? entry.intersectionRatio : 0)
            }
            updateActiveTheme()
          },
          {
            threshold: [0, 0.15, 0.3, 0.45, 0.6, 0.75, 0.9],
            rootMargin: '-20% 0px -30% 0px',
          }
        )

        for (const section of themeSections) {
          visibleRatios.set(section.id, 0)
          observer.observe(section)
        }
      }
    </script>
  </body>
</html>
